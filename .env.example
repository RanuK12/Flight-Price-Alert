# ============================================================
# Flight Deal Bot v4.0 — Variables de entorno
# ============================================================
# Copiar a .env (local) y/o configurar en Render Dashboard.
# .env NO se commitea (ver .gitignore).
# ============================================================

# --- Runtime -------------------------------------------------
NODE_ENV=development
PORT=4000
LOG_LEVEL=info           # debug | info | warn | error
TZ=America/Argentina/Buenos_Aires

# --- Telegram (obligatorio) ---------------------------------
# Token de @BotFather. Chat IDs separados por coma (admins/broadcast).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Polling (true) o webhooks (false). En Render free tier: polling.
TELEGRAM_POLLING=true

# --- Amadeus Self-Service API (obligatorio) ----------------
# Obtener en https://developers.amadeus.com → My Self-Service Workspace
# Base URL:
#   test.api.amadeus.com   → tier gratuito, datos demo
#   api.amadeus.com        → producción (datos reales, requiere billing)
AMADEUS_API_KEY=
AMADEUS_API_SECRET=
AMADEUS_BASE_URL=https://api.amadeus.com
# Requests/segundo permitidos en prod (Amadeus limita por endpoint).
AMADEUS_RATE_LIMIT_RPS=8
# Cuota mensual de seguridad (hard-stop antes de facturar extra).
AMADEUS_MONTHLY_BUDGET=2000

# --- Scheduler ----------------------------------------------
# Cron para monitoreo de fondo (scraper Google Flights).
MONITOR_SCHEDULE=0 */2 * * *
# Cron para informe diario PDF (21:00 ART por default).
DAILY_REPORT_SCHEDULE=0 21 * * *
AUTO_MONITOR=true

# --- Providers / caché --------------------------------------
# TTL cache respuestas Amadeus (ms). 6h es razonable.
CACHE_TTL_MS=21600000
# TTL cache Google Flights (ms). 1h.
CACHE_TTL_GF_MS=3600000

# --- Puppeteer (fallback scraper) --------------------------
# Dejar vacío en local; en Docker/Render usa el binario del sistema.
PUPPETEER_EXECUTABLE_PATH=

# --- Base de datos ------------------------------------------
# Path relativo al root del proyecto. Render free tier: efímero
# (se pierde en redeploy). Para persistencia usar Render disk.
SQLITE_PATH=./data/flights.db
